# Azure SQL
AZURE_SQL_SERVER=your-server.database.windows.net
AZURE_SQL_DATABASE=finance_app
AZURE_SQL_USE_MANAGED_IDENTITY=false
AZURE_SQL_USER=local_sql_user
AZURE_SQL_PASSWORD=local_sql_password

# Auth.js / NextAuth with Microsoft Entra ID
AUTH_SECRET=replace-with-long-random-secret
AUTH_MICROSOFT_ENTRA_ID_ID=entra-client-id
AUTH_MICROSOFT_ENTRA_ID_SECRET=entra-client-secret
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0

# Optional observability
APPLICATIONINSIGHTS_CONNECTION_STRING=
